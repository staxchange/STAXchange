{
  "name": "stax-ecommerce-shell-dwg",
  "version": "0.1.0",
  "private": true,
  "description": "Cloneable governed ecommerce shell with the DWG brand dress layered on top.",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "brands/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build --concurrency=1",
    "build:storefront": "npm run build --workspace @stax/storefront",
    "build:admin": "npm run build --workspace @stax/admin",
    "lint": "turbo run lint --concurrency=1",
    "typecheck": "turbo run typecheck --concurrency=1",
    "test": "jest --passWithNoTests",
    "validate:boundaries": "node scripts/validate-boundaries.mjs",
    "workflow:print": "node scripts/print-workflows.mjs",
    "audit:support": "node scripts/audit-support-workflow.mjs",
    "audit:service": "node scripts/audit-service-interface.mjs",
    "audit:service:prod": "node scripts/audit-service-production.mjs",
    "audit:technician": "node scripts/audit-technician-portal.mjs",
    "build:technician": "npm run build --workspace @stax/technician",
    "audit:billing": "node scripts/audit-service-billing.mjs",
    "audit:customer-ops": "node scripts/audit-customer-ops.mjs",
    "audit:accounting-export": "node scripts/audit-accounting-export.mjs",
    "audit:accounting-storage": "node scripts/audit-accounting-export-storage.mjs",
    "audit:finance-export-ui": "node scripts/audit-finance-export-ui.mjs",
    "audit:auth": "node scripts/audit-auth-guards.mjs",
    "audit:theme": "node scripts/audit-boiler-room-theme.mjs",
    "audit:visual": "node scripts/audit-visual-system.mjs",
    "audit:storefront-conversion": "node scripts/audit-storefront-conversion.mjs",
    "audit:launch": "node scripts/audit-launch-readiness.mjs",
    "audit:deployment": "node scripts/audit-deployment-hardening.mjs",
    "smoke:storefront": "node scripts/smoke-storefront.mjs",
    "smoke:api": "node scripts/smoke-api-routes.mjs",
    "preflight:prod": "node scripts/preflight-production.mjs",
    "audit:master": "node scripts/audit-master-bundle.mjs",
    "audit:all": "npm run audit:master && npm run audit:deployment && npm run audit:launch && npm run audit:storefront-conversion && npm run audit:visual && npm run audit:theme && npm run audit:auth && npm run audit:finance-export-ui && npm run audit:accounting-storage && npm run audit:accounting-export && npm run audit:billing && npm run audit:customer-ops && npm run audit:technician && npm run audit:service && npm run validate:boundaries",
    "smoke:admin": "node scripts/smoke-admin.mjs",
    "smoke:customer": "node scripts/smoke-customer.mjs",
    "smoke:technician": "node scripts/smoke-technician.mjs",
    "audit:vertical": "node scripts/audit-vertical-isolation.mjs",
    "audit:secret-exposure": "node scripts/audit-secret-exposure-strong.mjs",
    "audit:production-surface": "node scripts/audit-production-surface.mjs",
    "audit:repo-strength": "npm run audit:vertical && npm run audit:secret-exposure && npm run audit:production-surface",
    "audit:all-strengthened": "npm run audit:e2e-commerce && npm run audit:commerce-billing && npm run audit:accounting-handoff && npm run audit:supplier-purchasing && npm run audit:fulfillment && npm run audit:payments && npm run audit:quote-delivery && npm run audit:pricing && npm run audit:quote-documents && npm run audit:photo-quote && npm run audit:c3 && npm run audit:photo-quote && npm run audit:c3 && npm run audit:commerce && npm run audit:repo-strength && npm run audit:master && npm run audit:all",
    "supabase:check": "node scripts/supabase-check.mjs",
    "audit:commerce": "node scripts/audit-commerce-activation.mjs",
    "audit:photo-quote": "node scripts/audit-photo-quote-intake.mjs",
    "audit:c3": "node scripts/audit-c3-dress.mjs",
    "audit:quote-documents": "node scripts/audit-quote-documents.mjs",
    "audit:pricing": "node scripts/audit-pricing-governance.mjs",
    "audit:quote-delivery": "node scripts/audit-quote-delivery.mjs",
    "audit:payments": "node scripts/audit-payments.mjs",
    "audit:fulfillment": "node scripts/audit-fulfillment.mjs",
    "audit:supplier-purchasing": "node scripts/audit-supplier-purchasing.mjs",
    "audit:commerce-billing": "node scripts/audit-commerce-billing.mjs",
    "audit:accounting-handoff": "node scripts/audit-accounting-handoff.mjs",
    "audit:e2e-commerce": "node scripts/audit-e2e-commerce-readiness.mjs",
    "seed:demo:dry-run": "node scripts/seed-demo-commerce-dry-run.mjs"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
